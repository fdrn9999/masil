# =============================================================
#  script_ep2.rpy  —  Ep.2 (도윤 · 문래/건대 술자리 밤)  [장편 확장본]
# =============================================================
#  필요: effects / screens_chat / screens_map / systems_affection / systems_items / ep1
#  연결: ep1_wrap → episode2_full,  ep2_wrap → episode3_full
#  게임성: 장소 분기(문래/건대) · 아이템(숙취해소제 콜백, 도윤 키링) · 텍스팅 인터루드
# =============================================================

# ---------- 임시 배경 ----------
image bg pojang       = Solid("#3a2f2a")   # 문래 골목 조용한 술집
image bg konkuk       = Solid("#33282f")   # 건대 먹자골목 (시끌)
image bg street_night = Solid("#1b1f2e")   # 밤거리
image bg mullae_alley = Solid("#2a2722")   # 문래 창작촌 골목

# ---------- Ep.2 상태 ----------
default doyun_secret_seen = False   # 도윤의 과거(민결 떡밥)를 캐물었는지
default meet_loc = ""               # 만남 장소: mullae / konkuk


label episode2_full:

    $ chapter_start()
    $ show_gauges = False

    scene bg black with fade
    centered "{size=50}Ep.2{/size}\n\n문래, 그 골목의 밤"
    with Pause(1.2)

    # ------------------------------------------------------------
    #  텍스팅 인터루드 — 며칠간, 도윤과 톡으로 가까워진다
    # ------------------------------------------------------------
    scene bg room with dissolve
    $ pmusic("audio/bgm/bgm_daily.ogg")
    n "서아와의 일이 한 매듭 지어지고 며칠. 도윤은 그 사이에도 하루가 멀다 하고 톡을 보냈다."
    n "녀석은 신기한 재주가 있었다. 내가 가라앉아 있는 날이면, 꼭 그날 따라 시답잖은 톡을 보내왔다."

    $ chat_reset("도윤")
    show screen masil_chat with Dissolve(0.4)
    $ recv("형 살아있음? ㅋㅋ", name="도윤")
    pause

    # Ep.1 결말 연속성 콜백
    if seoa_result == "breakup":
        $ recv("형, 서아 누나랑 깨졌다며. 괜찮아?", name="도윤")
        pause
        $ send("괜찮아 인마. 그럴 수도 있지")
        pause
        $ recv("형 또 혼자 삭이고 있지 ㅋㅋ 안 봐도 비디오다", name="도윤")
        pause
    elif seoa_result == "slow":
        $ recv("서아 누나랑 천천히 가기로 했다며? 형 멋있던데 ㅋㅋ", name="도윤")
        pause
        $ send("뭘 또 멋있어. 그냥 그런 거지")
        pause
        $ doyun_bond += 3
    elif seoa_result == "fizzle":
        $ recv("서아 누나 일은 뭐… 그래도 형이 도망은 안 쳤잖아", name="도윤")
        pause
        $ send("응. 그건 그래")
        pause
    else:
        $ recv("형 요즘 연애는 함? 오픈챗은 계속 하고?", name="도윤")
        pause
        $ send("그냥 눈팅이나 하지 뭐")
        pause

    # 도윤의 일상 텍스처 + 외로움 한 자락(농담으로 덮는다)
    $ recv("형 어제 나 새벽 네 시까지 게임함 ㅋㅋ 진짜 폐인 다 됐어", name="도윤")
    pause
    $ send("너 잠은 자냐. 몸 상한다 인마")
    pause
    $ recv("자면 뭐함 ㅋㅋ 어차피 깨면 또 혼자인데", name="도윤")
    pause
    $ recv("아 이건 그냥 한 말이고! 형 걱정 ㄴㄴ ㅋㅋㅋ", name="도윤")
    pause
    n "농담 뒤에 슬쩍 흘린 한마디가,{w=0.3} 묘하게 오래 걸렸다.{w=0.4} '깨면 또 혼자.' — 그건, 내가 매일 천장 보면서 하던 생각이기도 했으니까."

    $ recv("아 됐고! 형 이번 주말에 시간 됨?", name="도윤")
    pause
    $ recv("나 형이랑 진지하게 한잔 하고 싶어서. 별일은 아니고 ㅋㅋ", name="도윤")
    pause
    $ send("진지하게? 너 또 무슨 사고 쳤냐")
    pause
    $ recv("아니거든?! 그냥… 형한테 하고 싶은 얘기 있어서. 진짜야", name="도윤")
    pause

    hide screen masil_chat with Dissolve(0.4)
    n "'진지하게'라는 말이 도윤 입에서 나오는 건 드문 일이었다.{w=0.3} 그 녀석은 진심일수록 농담으로 포장하는 버릇이 있었으니까.{w=0.4} 그게 바로, 나랑 똑 닮은 점이기도 했다."

    # ------------------------------------------------------------
    #  장소 선택 — 어디서 볼까 (분위기·전개가 달라진다)
    # ------------------------------------------------------------
    n "어디서 볼지는 나한테 맡긴다고 했다."
    menu:
        n "── 도윤이랑 어디서 한잔할까? ──"

        "문래 — 조용한 골목 술집 (진솔한 대화)":
            $ meet_loc = "mullae"
            jump ep2_meet_mullae

        "건대 — 시끌벅적 먹자골목 (텐션 먼저)":
            $ meet_loc = "konkuk"
            jump ep2_meet_konkuk


label ep2_meet_mullae:
    $ unlock_station("mullae")
    n "잠실에서 2호선. 문래역이 새로 열렸다."
    call screen subway_map

    scene bg pojang with fade
    $ pmusic("audio/bgm/bgm_night_talk.ogg", fadein=1.2)
    n "문래 창작촌 안쪽, 간판도 희미한 작은 술집. 도윤이 먼저 와 소주잔을 만지작거리고 있었다."
    d "형 왔어? 앉아 앉아. 오늘은 내가 살게."
    n "처음부터 분위기가 조용했다. 도윤도 평소처럼 까불지 않고, 어딘가 가라앉아 있었다."
    d "여기 내가 가끔 혼자 오는 데야.{w=0.4} 시끄러운 데선 못 할 얘기가 있을 때, 딱 여기."
    n "도윤이 내 잔에 소주를 채웠다. 평소 같으면 '원샷!' 하며 깔깔댔을 녀석이, 오늘은 잔이 차오르는 걸 가만히 보고만 있었다."
    mc "무슨 얘긴데 그래. 뜸 들이지 말고."
    d "어어. 천천히 하자.{w=0.3} 오늘은 좀… 길어질 거 같으니까."
    $ doyun_bond += 3
    jump ep2_heart


label ep2_meet_konkuk:
    $ unlock_station("konkuk")
    n "잠실에서 2호선. 건대입구역이 새로 열렸다."
    call screen subway_map

    scene bg konkuk with fade
    $ pmusic("audio/bgm/bgm_comedy.ogg", fadein=0.8)
    n "건대 먹자골목은 발 디딜 틈이 없었다. 도윤은 벌써 닭발에 소주를 시켜놓고 손을 흔들었다."
    d "형! 여기 여기! 일단 한 잔 받아요, 얘기는 좀 있다 하고!"
    n "시끄러운 게 차라리 나았다. 우리는 한참을 그냥 먹고 마시며 시답잖은 농담을 주고받았다."
    n "도윤이 닭발이 맵다고 콜라를 들이켜는 꼴이 어찌나 웃긴지, 한참을 웃었다."
    $ doyun_bond += 2
    n "그렇게 한 시간쯤 떠들고 나서야, 도윤이 슬쩍 자리를 옮기자고 했다."
    scene bg street_night with dissolve
    n "사람 없는 골목 벤치에 나란히 앉았다. 시끄럽던 녀석이, 거기서부터 조용해졌다."
    $ pmusic("audio/bgm/bgm_night_talk.ogg", fadein=1.2)
    jump ep2_heart


# ------------------------------------------------------------
#  공통 — 진짜 대화, 과거의 암시, 그리고 거울
# ------------------------------------------------------------
label ep2_heart:
    # 친구의 세계 — 왜 늘 새벽까지 깨어 있나 (도윤의 외로움 = 주인공의 거울)
    n "몇 잔이 오갔다. 시답잖은 게임 얘기, 회사 욕, 누가 더 폐인인지 따지는 시시한 경쟁."
    n "그러다 문득, 도윤이 천장을 올려다보며 중얼거렸다."
    d "형은 왜 오픈챗 깔았어?"
    mc "글쎄.{w=0.3} …그냥, 방이 너무 조용해서."
    d "ㅋㅋ 똑같네 우리.{w=0.4} 나도 그래. 보이스룸 켜놓고 자야 잠이 와.{w=0.3} 마이크 너머에 누가 숨 쉬고 있다는 거, 그게 좋더라고."
    n "능청맞게 웃는데, 그 웃음 끝이 어쩐지 시렸다.{w=0.4} 화면 속에서 제일 밝던 녀석이, 사실은 제일 외로운 놈일 수도 있다는 걸 — 그제야 알았다."

    menu:
        n "도윤의 그 말에, 뭐라고 답할까?"

        "나도 그랬다고, 솔직하게":
            mc "나도 그래.{w=0.3} 너 마이크 너머에 있어줘서, 그 방이 덜 조용했어."
            $ doyun_bond += 6
            d "……형.{w=0.4} 그런 말 술자리에서 하면 반칙이지."
            n "도윤이 괜히 안주만 뒤적였다. 귀가 살짝 붉어져 있었다."

        "농담으로 받아준다":
            mc "폐인 둘이 용케 만났네. 천생연분이다 우리 ㅋㅋ"
            $ doyun_bond += 2
            d "ㅋㅋㅋ 인정. 형, 우리 그냥 같이 살까?"

    # 톤 전환 신호 (개그→진지 완충)
    n "몇 잔이 더 돌았다. 도윤이 잔을 가만히 내려놓았다.{w=0.3} 능청스러운 가면이 조금씩 벗겨졌다."
    d "형.{w=0.3} 그날 밤 기억나?{w=0.4} 내가 길바닥에서 개진상 부리던 거."
    mc "당연히 기억나지.{w=0.3} 너 그날 진짜 무서웠어."
    d "그때 형이 날 안 잡아줬으면…{w=0.4} 나 진짜 어떻게 됐을지 몰라."
    n "녀석은 잔을 빙글빙글 돌리면서, 한참 입을 다물고 있었다."

    # --- 아이템 콜백: 남은 숙취해소제 ---
    if has_item("hangover"):
        menu:
            n "가방 안에, 그날 밤 챙겨둔 숙취해소제가 아직 하나 남아 있었다."

            "숙취해소제를 슬쩍 건넨다":
                $ give_item("hangover", "doyun")
                $ doyun_bond += 8
                mc "야, 천천히 마셔. 이거나 먹고."
                n "도윤이 그걸 받아들고 잠깐 멍하니 보더니, 픽 웃었다."
                d "…형, 이거 그날 그거잖아. 아직도 갖고 다녔어?"
                mc "어쩌다 보니. 너 또 이럴까 봐."
                d "(작게) ……형은 진짜. 사람을 울리는 재주가 있어."

            "그냥 말없이 옆에 둔다":
                n "괜히 꺼내면 분위기를 깰 것 같아, 그냥 두기로 했다."

    menu:
        n "도윤에게 뭐라고 할까?"

        "친구니까 당연한 거라고 말한다":
            mc "야, 친구가 무너지는데 그냥 둬?{w=0.3} 당연한 거야."
            $ doyun_bond += 10
            d "……형은 그걸 '당연하다'고 생각하는 게,{w=0.4} 형의 제일 좋은 점이야."

        "그날 왜 그렇게까지 무너졌는지 묻는다":
            mc "근데 너 그날…{w=0.3} 왜 그렇게까지 됐던 거야?{w=0.4} 무슨 일 있었어?"
            $ doyun_secret_seen = True
            $ doyun_bond += 5
            d "……."
            d "한 사람 때문이었어.{w=0.4} 내가 진짜… 믿었던 사람."
            d "오픈챗에서 만났는데…{w=0.3} 말은 또 어찌나 야무진지. 나 같은 건 말로 백 번을 져줬어 ㅋㅋ"
            d "근데 내가 제일 바닥일 때,{w=0.4} 딱 그때 등을 돌리더라.{p}아직도 그 사람 생각하면, 손이 떨려."
            with flash_black
            n "도윤의 눈빛이 잠깐,{w=0.3} 내가 모르는 누군가를 향하는 것 같았다."
            n "'말이 야무진 사람.'{w=0.3} 그땐 그냥 흘려들은 그 한마디가, 나중에 이렇게 돌아올 줄은 — 그땐 정말 몰랐다."
            d "언젠가 형한테 다 말할게.{w=0.4} 오늘은… 여기까지만."

    # --- 도윤이 주는 아이템: 우정의 증표 ---
    d "아 맞다. 형, 이거."
    n "도윤이 자기 가방에서 낡은 키링을 풀어, 내 손에 턱 쥐여줬다."
    d "우정의 증표 ㅋㅋ. 형이 갖고 있어. 나 이거 진짜 아끼는 건데, 형한테는 줄 수 있어."
    $ get_item("doyun_keyring")
    mc "뭐야 이게. 갑자기 오글거리게."
    d "나중에 형 진짜 힘들 때, 그거 보면서 내 생각 해 줘. 알겠지 형?"
    mc "…알겠어. 진짜 오글거리니까, 딱 한 번만 받아준다."
    d "ㅋㅋㅋ 됐고. 우리 룸메 없는 룸메잖아.{w=0.4} 룸메끼린 원래 이런 거 주고받는 거야."
    n "오픈챗에서 처음 만난 날 던졌던 그 말을,{w=0.3} 녀석은 아직 기억하고 있었다."

    # ------------------------------------------------------------
    #  거울 구조 — 이번엔 내가 취하고, 도윤이 챙긴다
    # ------------------------------------------------------------
    scene bg street_night with longdissolve
    $ pmusic("audio/bgm/bgm_emotional.ogg", fadein=1.2)
    n "그날따라 술이 빨리 올랐다.{w=0.3} 어느새 비틀거리는 건 내 쪽이었다."
    n "이상한 밤이었다. 평소엔 절대 안 하던 말이, 술기운을 타고 자꾸 새어 나왔다."
    mc "(취해서) 도윤아…{w=0.4} 나 사실… 사람 사귀는 거 무서워.{p}또 망칠까 봐."

    menu:
        n "취중진담, 어디까지 말할까?"

        "속마음을 다 털어놓는다":
            with vpunch
            mc "다들 나한테 가벼운 놈이래.{w=0.3} 근데 난…{w=0.4} 진심 줬다가 버려지는 게 무서운 거야."
            mc "그래서 매번 먼저 가벼운 척하고,{w=0.3} 가까워질 것 같으면 한 발 빼.{p}나, 진짜 별로지."
            $ doyun_bond += 10
            d "형."
            d "그날 새벽에 형이 나한테 했던 말, 기억나?{w=0.4} '일어나. 집에 가자. 내가 데려다줄게.'"
            d "그거 오늘은 내가 형한테 할게.{p}형, 일어나.{w=0.3} 집에 가자.{w=0.4} 별로인 거 아니야. 그냥, 많이 데였던 거지."
            n "도윤이 내 어깨를 단단히 붙잡았다.{w=0.4} 그날 밤, 내가 녀석에게 그랬던 것처럼 —{w=0.3} 거울처럼, 똑같이."

        "괜찮은 척 웃어넘긴다":
            mc "아냐 아냐, 취해서 헛소리한 거야 ㅋㅋ"
            d "……형.{w=0.4} 그 가면, 나한텐 안 통해.{w=0.3} 그래도 오늘은 봐줄게."

    d "집까지 데려다줄게.{w=0.4} 이번엔… 내 차례야 형."
    $ pmusic("audio/bgm/bgm_warm.ogg", fadein=1.5)
    n "비틀거리는 나를, 도윤이 택시에 실었다."
    n "오픈챗에서 만난 한 살 어린 동생은,{w=0.3} 어느새 내가 가장 기댈 수 있는 사람이 되어 있었다."
    $ pstop(fadeout=2.0)

    jump ep2_wrap


label ep2_wrap:
    scene bg black with fade
    n "── Ep.2 끝 ──"
    if doyun_secret_seen:
        n "(도윤의 과거에 '오픈챗에서 만난 한 사람'이 있다.{w=0.3} 언젠가, 다시 마주칠지도…)"
    else:
        n "(도윤은 아직 자기 과거를 다 말하지 않았다.)"
    n "(도윤 우정 [doyun_bond])"

    $ show_gauges = False
    hide screen affection_gauges
    n "다음 역, 다음 사람에게로. (Ep.3 — 지우)"

    # 이어서 Ep.3 (단독 테스트하려면 아래 줄을 return 으로)
    jump episode3_full
