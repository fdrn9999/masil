        {
         "op": "pause"
        }
       ]
      }
     ]
    }
   ]
  },
  {
   "op": "recv",
   "name": "도윤",
   "text": "형 어제 나 새벽 네 시까지 게임함 ㅋㅋ 진짜 폐인 다 됐어"
