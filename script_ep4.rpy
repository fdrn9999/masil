# =============================================================
#  script_ep4.rpy  —  Ep.4 (민결 · 강남 · 반전/클라이맥스)  [장편 확장본]
# =============================================================
#  필요: effects / screens_chat / screens_map / systems_affection / systems_items / ep1~3
#  연결: ep3_wrap → episode4_full,  ep4_wrap → epilogue_full
#  게임성: 오픈챗 말다툼 텍스팅 · '누구 먼저 들을까' 장소분기 · 도윤 키링 회수 · 4엔딩 게이팅
# =============================================================

# ---------- 임시 배경 ----------
image bg gangnam    = Solid("#2b2b33")   # 강남 밤거리 (네온)
image bg rooftop    = Solid("#22283a")   # 옥상 바
image bg doyun_room = Solid("#241f1f")   # 도윤의 방

# ---------- 캐릭터 ----------
define m = Character("민결", color="#b06cc0")

# ---------- Ep.4 상태 ----------
default mingyeol_truth_known = False
default ep4_choice = ""       # 최종 선택: reconcile / love / friend / run
default heard_side = ""       # 먼저 들은 쪽: doyun / mingyeol


label episode4_full:

    $ chapter_start()
    $ show_gauges = False

    scene bg black with fade
    centered "{size=50}Ep.4{/size}\n\n돌아온 이름"
    with Pause(1.2)

    # ------------------------------------------------------------
    #  오픈챗 말다툼 → 정드는 텍스팅 (떨어져서 부딪히고 가까워짐)
    # ------------------------------------------------------------
    scene bg room with dissolve
    $ pmusic("audio/bgm/bgm_daily.ogg")
    n "그 사람은, 싸우면서 처음 알게 됐다."
    n "어느 오픈챗 토론방. 사소한 주제 하나로 한 사람과 제대로 붙었다."

    $ chat_reset("자유 토론방")
    show screen masil_chat with Dissolve(0.4)
    $ recv("그건 님 생각이고요. 논리가 너무 빈약한데요?", name="민결")
    pause
    $ send("빈약한 건 그쪽 태도 같은데요")
    pause
    $ recv("ㅋ 적어도 전 도망은 안 가요. 끝까지 말은 하니까.", name="민결")
    pause
    n "'도망 안 간다'는 그 말이, 이상하게 오래 걸렸다.{w=0.3} 내가 평생 해온 거라곤 도망이었으니까."

    n "답을 얼마나 빨리 할까.{w=0.3} 이 사람한텐, 그것마저 시험 같다."
    call reply_prompt("mingyeol")

    menu:
        n "이 사람, 뭔가 다르다. 어떻게 받을까?"

        "지지 않고 받아친다":
            $ send("도망 안 가는 거 하나는 인정. 그쪽 꽤 솔직하네요")
            $ add_like("mingyeol", 10)
            $ recv("…뭐예요 갑자기. 김 빠지게.", name="민결")
            pause

        "한발 물러서 인정한다":
            $ send("하긴 제가 말이 좀 셌네요. 미안해요")
            $ add_sincere("mingyeol", 10)
            $ recv("…사과할 줄도 아네. 의외다 진짜.", name="민결")
            pause

    # 며칠에 걸쳐 톡이 이어진다
    $ recv("아 그리고 아까 그 얘기 말인데요, 다시 생각해보니 님 말도 일리는 있더라", name="민결")
    pause
    $ send("오 인정할 줄도 알고")
    pause
    $ recv("ㅋㅋ 저 원래 맞으면 맞다고 해요. 싸우다 정든다더니 우리가 그 짝이네", name="민결")
    pause
    $ recv("강남에서 한잔 어때요? 얼굴 보고 더 싸워보든가.", name="민결")
    pause
    hide screen masil_chat with Dissolve(0.4)
    n "며칠 사이, 우리는 매일 그렇게 티격태격하면서도 톡을 놓지 않았다.{w=0.4} 날카로운 사람인 줄만 알았는데, 말끝마다 묘하게 쓸쓸한 구석이 있었다."

    # ------------------------------------------------------------
    #  반전 — 도윤이 민결을 안다
    # ------------------------------------------------------------
    scene bg room with dissolve
    n "별 생각 없이, 도윤에게 민결 이야기를 꺼냈다."
    d "형, 새로 알게 된 사람?{w=0.3} 이름이 뭔데."
    mc "민결이라고.{w=0.3} 오픈챗에서 싸우다 친해졌어."
    d "……."
    pause 0.6
    d "형.{w=0.4} 그 사람…{w=0.4} 혹시 프로필 사진 보여줄 수 있어?"

    pause 0.4
    scene bg room with flash_black
    $ pmusic("audio/bgm/bgm_tension.ogg", fadein=0.6)
    with vpunch
    n "사진을 본 도윤의 얼굴이,{w=0.3} 하얗게 굳었다."

    if doyun_secret_seen:
        d "형. 나 저번에 문래에서 말했지.{w=0.3} 내가 오픈챗에서 만나서, 끝이 더러웠던 사람."
        d "그게…{w=0.4} 민결이야. 그 사람이라고."
        $ mingyeol_truth_known = True
        n "문래의 그 밤, 도윤이 손을 떨며 말하던 '그 사람'.{w=0.4} 하필, 내가 막 끌리기 시작한 그 사람이었다."
    else:
        d "형…{w=0.3} 나 형한테 다 말 안 한 게 있었어."
        d "그 사람, 나랑 오픈챗에서 만났던 사람이야.{w=0.4} 끝이… 진짜 더러웠어."
        $ mingyeol_truth_known = True
        n "도윤이 한 번도 꺼내지 않았던 과거가,{w=0.3} 이런 식으로 돌아왔다."

    d "형이 누굴 만나든 난 응원해.{w=0.3} 근데… 이건 좀 다르잖아."
    d "형이 정해.{w=0.4} 난 형 편이니까. 어느 쪽이든."

    # ------------------------------------------------------------
    #  장소/순서 선택 — 누구 얘기를 먼저 제대로 들을까
    # ------------------------------------------------------------
    n "머리가 복잡했다. 어느 쪽이든, 그 전에 — 누구 얘기를 먼저 들어야 할까."
    menu:
        n "── 누구를 먼저 찾아갈까? ──"

        "도윤을 붙잡고, 다 듣는다 (문래)":
            $ heard_side = "doyun"
            jump ep4_hear_doyun

        "일단 민결을 만나, 직접 묻는다 (강남)":
            $ heard_side = "mingyeol"
            jump ep4_hear_mingyeol


label ep4_hear_doyun:
    scene bg doyun_room with dissolve
    $ pmusic("audio/bgm/bgm_night_talk.ogg", fadein=1.0)
    n "그날 밤, 도윤의 방에 찾아갔다. 녀석은 한참을 망설이다, 처음으로 다 털어놨다."
    d "걔랑 나, 진짜 좋았어. 근데… 내가 제일 약했을 때, 걔가 날 제일 아프게 떠났어."
    d "그날 형이 길바닥에서 주워 온 나, 그게 다 걔 때문이었어."
    n "녀석의 목소리가 떨렸다. 농담으로 덮을 수 없는 진짜 상처였다."
    $ doyun_bond += 5

    if has_item("doyun_keyring"):
        n "주머니 속, 도윤이 준 키링이 만져졌다. '형이 진짜 힘들 때 보면서 나 생각해.'{w=0.3} 그 말이 지금은 거꾸로, 내 손을 무겁게 했다."
        d "형 그거… 아직도 갖고 있었네."
        d "형. 형 마음 가는 대로 해도 돼. 진짜야. 근데 나, 형이 그것까지 들고 있는 거 보니까 — 좀 견딜 만하다."
        $ doyun_bond += 5

    n "도윤의 상처를 먼저 안고, 나는 강남으로 향했다."
    jump ep4_gangnam


label ep4_hear_mingyeol:
    n "도윤에게는 미안했지만, 나는 먼저 민결을 만나 직접 묻기로 했다.{w=0.3} 한쪽 말만 듣고 사람을 판단하고 싶진 않았다."
    jump ep4_gangnam


# ------------------------------------------------------------
#  강남 — 민결과의 만남
# ------------------------------------------------------------
label ep4_gangnam:
    scene bg gangnam with fade
    n "복잡한 마음으로 2호선을 탔다. 강남이 새로 열렸다."
    $ unlock_station("gangnam")
    call screen subway_map

    scene bg rooftop with dissolve
    $ pmusic("audio/bgm/bgm_warm.ogg", fadein=1.0)
    n "강남의 한 옥상 바. 네온 불빛 아래 민결이 먼저 와 있었다."
    m "왔네요.{w=0.3} 톡에선 그렇게 세더니, 실물은 순하게 생겼네 ㅋㅋ"
    n "날카로운 줄만 알았던 민결은, 마주 앉으니 의외로 쓸쓸한 눈을 하고 있었다."
    m "나 사실… 사람들이 날 오해 많이 해요. 세 보인다고.{w=0.4} 먼저 상처 주기 전에 벽 치는 거예요."

    menu:
        n "민결의 벽 앞에서, 어떻게 할까?"

        "그 벽을 이해한다고 말한다":
            mc "알 것 같아요.{w=0.3} 다치기 싫어서 먼저 세게 나가는 거."
            $ add_sincere("mingyeol", 15)
            m "……어떻게 알았어요.{w=0.3} 좀 무섭다, 그쪽."

        "도윤 이야기를 꺼낸다":
            mc "혹시…{w=0.3} '도윤'이라는 사람, 알아요?"
            n "민결의 표정이 단번에 굳었다. 잔을 쥔 손가락이 하얗게 변했다."
            m "……알아요.{w=0.4} 내가, 제일 크게 잘못한 사람."
            m "그때 난 너무 어렸고, 너무 비겁했어요. 도망쳤거든요. 걔가 제일 힘들 때."
            $ mingyeol_truth_known = True
            $ add_sincere("mingyeol", 10)
            n "날카로운 가시 뒤에, 오래 묵은 죄책감이 있었다.{w=0.4} 민결은 그 일을, 한순간도 잊은 적이 없는 사람이었다."

    # heard_side에 따른 추가 한 줄
    if heard_side == "mingyeol" and not doyun_secret_seen:
        m "혹시… 그쪽, 도윤이 알아요? 그 표정 보니까."
        mc "어. 내 제일 친한 동생이에요."
        m "…세상 진짜 좁네요. 하필."

    # ------------------------------------------------------------
    #  서아 카메오 + 마음 정리 (집 가는 길)
    # ------------------------------------------------------------
    scene bg black with dissolve
    n "복잡한 마음으로 돌아가던 길, 뜻밖의 톡이 울렸다."
    $ chat_reset("서아")
    show screen masil_chat with Dissolve(0.4)
    $ recv("오랜만! 잘 지내요? ㅋㅋ 문득 생각나서", name="서아")
    pause
    $ recv("그때 내가 너무 빨리 들이댔죠. 미안. 나 그땐 좀 무서웠나봐", name="서아")
    pause
    $ recv("지금은 내 속도 찾았어요. 그쪽도 잘 지내길!", name="서아")
    pause
    hide screen masil_chat with Dissolve(0.4)
    n "빠르게 스쳐간 사람도, 어딘가에서 자기 속도로 자라고 있었다.{w=0.4} …나는 지금, 내 속도로 진심을 마주하고 있나."

    # ------------------------------------------------------------
    #  딜레마 — 친구 vs 사랑
    # ------------------------------------------------------------
    scene bg black with fade
    $ pmusic("audio/bgm/bgm_emotional.ogg", fadein=1.2)
    n "집으로 돌아오는 길. 머릿속이 복잡했다."
    n "민결에게 끌린다.{w=0.3} 하지만 그 사람은, 도윤에게 가장 깊은 상처를 준 사람."
    d "(톡) 형. 고민 많지.{w=0.3} 천천히 정해도 돼.{w=0.4} 진짜 형 마음대로 해."

    if has_item("doyun_keyring"):
        n "주머니에서 도윤의 키링을 꺼내 한참 들여다봤다.{w=0.4} 이 작은 쇳덩이가, 오늘따라 너무 무거웠다."

    menu:
        n "── Ep.4 — 그리고 이 이야기의 답을 정하는 선택 ──"

        "도윤과 함께, 진실을 마주하고 셋이 풀어본다":
            $ ep4_choice = "reconcile"
            jump ep4_end_reconcile

        "민결을 선택한다 (도윤과는 멀어지더라도)":
            $ ep4_choice = "love"
            jump ep4_end_love

        "도윤과의 의리를 지킨다 (민결을 정리한다)":
            $ ep4_choice = "friend"
            jump ep4_end_friend

        "둘 다 감당 못 하고 도망친다":
            $ ep4_choice = "run"
            jump ep4_end_run


# ---------- 화해 루트 ----------
label ep4_end_reconcile:
    scene bg doyun_room with fade
    $ pmusic("audio/bgm/bgm_emotional.ogg", fadein=1.2)
    if doyun_bond >= 25 and sincere["mingyeol"] >= 35:
        n "나는 도윤과 민결을 한자리에 불렀다.{w=0.3} 가장 어렵고, 가장 무서운 선택이었다."
        n "처음 몇 분은 셋 다 아무 말도 못 했다. 잔 만지작거리는 소리, 에어컨 도는 소리.{w=0.4} 침묵이 칼날 같았다."
        d "형이…{w=0.4} 이렇게까지 할 줄은 몰랐어."
        mc "한쪽 말만 듣고 누굴 미워하긴 싫었어.{w=0.3} 너도, 얘도 — 둘 다 내 사람이니까."
        m "도윤아.{w=0.4} 그때… 정말 미안했어.{w=0.3} 사과할 자격 없는 거 알아. 근데 이건 꼭 말하고 싶었어."
        d "……."
        d "사과 받는다고 그날이 없던 일이 되진 않아.{w=0.4} 근데…{w=0.3} 적어도 이제, 그 얘길 꺼낼 수는 있게 됐네."
        n "오래 묵은 상처가 한 번에 낫진 않았다.{w=0.3} 그래도 셋은, 조금씩 마주 앉기 시작했다.{w=0.4} 그거면 됐다. 시작이 됐으니까."
        if has_item("doyun_keyring"):
            n "테이블 위에 도윤이 줬던 키링을 슬쩍 올려놨다. 녀석이 그걸 보고, 끝내 피식 웃었다."
            d "형. 형이라서 가능한 거였어.{w=0.4} 그날 길바닥에서 날 잡아준 사람이니까."
            d "형은 진짜…{w=0.3} 끝까지 아무도 안 놓는 사람이더라."
        n "── 진엔딩: '용서까지 데려다준 사람' (도윤도 민결도 잃지 않은 길)"
    else:
        n "셋이 마주 앉았지만, 아직 신뢰가 부족했다.{w=0.3} 상처는 그렇게 쉽게 아물지 않았다."
        n "도윤은 끝내 먼저 자리를 떴고, 민결은 한참을 빈 잔만 들여다봤다."
        n "그래도, 도망치지 않고 셋이 한 테이블에 앉았던 것만으로 — 아주 작은 시작은 됐다."
        n "── 보통 엔딩: '서툰 중재'"
    jump ep4_wrap


# ---------- 사랑 선택 루트 ----------
label ep4_end_love:
    scene bg black with fade
    if sincere["mingyeol"] >= 40:
        n "나는 민결을 선택했다.{w=0.3} 도윤에게는, 도망치지 않고 똑바로 말했다."
        mc "미안해. 근데 나, 이번엔 도망치고 싶지 않아.{w=0.3} 걔한테도, 나한테도."
        d "……알았어 형.{w=0.4} 형 행복이 우선이지.{w=0.3} 근데 난 좀, 시간이 필요해. 그건 이해해줘."
        mc "어. 기다릴게.{w=0.3} 네가 다시 웃으면서 욕해줄 때까지."
        n "도윤과는 잠시 멀어졌다. 그게 못내 아렸지만,{w=0.3} 민결과는 천천히, 진짜가 되어갔다."
        m "너는…{w=0.3} 나 같은 사람도 안 도망치고 마주해주네."
        mc "내가 제일 잘하는 게 도망이었거든.{w=0.4} 근데 너한테는, 안 그러기로 했어."
        n "가시밭인 걸 알면서도, 이번엔 그 길로 걸어 들어갔다.{w=0.4} 언젠가 도윤과도 다시 웃을 날이 오기를, 가만히 빌면서."
        n "── 엔딩: '가시밭의 사랑' (사랑은 얻고, 우정은 숙제로 남은)"
    else:
        n "민결을 택했지만, 진심이 충분히 쌓이지 않은 관계는 자꾸 흔들렸다."
        n "도윤과는 멀어졌고, 민결과도 끝내 깊어지지 못했다.{w=0.4} 둘 다 어중간하게, 손가락 사이로 빠져나갔다."
        n "── 씁쓸한 엔딩: '둘 다 어중간했던'"
    jump ep4_wrap


# ---------- 우정 선택 루트 ----------
label ep4_end_friend:
    scene bg doyun_room with fade
    n "나는 민결을 정리했다.{w=0.3} 도윤에게 더 큰 상처를 주고 싶지 않았다."
    n "민결에게 보낼 마지막 톡은, 썼다 지웠다를 오래 반복했다.{w=0.4} 「미안해요. 나한텐, 도윤이가 먼저예요.」 — 결국 그 한 줄을 보냈다."
    if doyun_bond >= 25 or has_item("doyun_keyring"):
        d "형…{w=0.4} 나 때문에 미안해. 근데 진짜… 고마워."
        d "형은 내 평생 은인이야.{w=0.4} 그날 길바닥에서도, 오늘도."
        mc "은인은 무슨.{w=0.3} 친구가 친구한테 그러는 거지."
        d "그래.{w=0.4} 친구.{w=0.3} 그 말이, 형한텐 제일 잘 어울려."
        if has_item("doyun_keyring"):
            n "도윤이 내 손에 쥐인 키링을 보고, 눈가가 붉어졌다.{w=0.3} 「그거, 끝까지 갖고 있었구나 형.」"
        n "사랑 하나를 접은 자리에,{w=0.3} 평생 갈 사람 하나가 더 단단히 남았다."
        n "── 도윤 우정 엔딩: '그날 그 손을 끝까지' (사랑보다 단단한 의리)"
    else:
        d "형, 고마워.{w=0.4} …근데 형도 형 행복 찾아야 돼. 나 신경 쓰지 말고."
        n "옳은 선택이었다.{w=0.3} 다만 그날 밤, 빈 방이 평소보다 조금 더 넓게 느껴졌다."
        n "── 엔딩: '의리는 지켰지만' (옳았으나 조금 허전한)"
    jump ep4_wrap


# ---------- 도피 루트 ----------
label ep4_end_run:
    scene bg black with fade
    n "나는 아무것도 정하지 못한 채, 둘 모두에게서 멀어졌다."
    n "민결의 톡에도, 도윤의 톡에도 답이 점점 늦어졌다.{w=0.4} 그러다 어느 날부턴, 아예 열어보지 않았다."
    n "오픈챗 알림은 점점 줄었고, 방은 조용해졌다.{w=0.4} 늘 그래왔듯 —{w=0.3} 나는 또, 도망쳤다."
    d "(도윤) 형 바쁜가 보네 ㅋㅋ 연락 줘."
    d "(도윤) ……형. 나 형 편이라니까. 진짜로."
    d "(읽음) ……."
    n "그 마지막 '읽음' 두 글자를,{w=0.3} 나는 한참을 그냥 들여다보기만 했다."
    n "── 엔딩: '다시 혼자' (가장 익숙하고, 가장 쓸쓸한 결말)"
    jump ep4_wrap


label ep4_wrap:
    scene bg black
    $ pstop(fadeout=2.0)
    $ k, who = final_ending()
    n "── Ep.4 끝 ──"
    n "(도윤 우정 [doyun_bond] / 최종 선택: [ep4_choice])"
    n "(최종 엔딩 판정 — 타입: [k] / 대상: [who])"
    n "오픈챗에서 시작된 이야기가, 여기서 한 매듭을 짓는다."

    $ show_gauges = False
    hide screen affection_gauges

    # 본편이 끝나면 '시간이 흐른 뒤' 에필로그로
    jump epilogue_full
